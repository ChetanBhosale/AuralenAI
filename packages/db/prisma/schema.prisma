generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  name        String?
  google_id   String  @unique
  profile_pic String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  agents   Agent[]
}

model Product {
  id                 Int    @id @default(autoincrement())
  name               String
  product_md         String
  website_url        String
  product_scrape_md  String
  prduct_description String

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targetAudience TargetAudience?
  workflowRuns   WorkflowRun[]
  agentProducts  AgentProduct[]

  @@index([userId])
}

model TargetAudience {
  id         Int           @id @default(autoincrement())
  job_roles  String[]
  industries String[]
  locations  String[]
  goal       OUTREACH_GOAL @default(BOOK_MEETING)
  target_description String

  productId Int     @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id           Int           @id @default(autoincrement())
  speech       SPEECH        @default(FORMAL)
  agent_md     String
  tone_context String?
  goal         OUTREACH_GOAL @default(BOOK_MEETING)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentProducts AgentProduct[]

  @@index([userId])
}

model AgentProduct {
  id Int @id @default(autoincrement())

  agentId   Int
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([agentId, productId])
  @@index([agentId])
  @@index([productId])
}

enum SPEECH {
  CASUAL
  FORMAL
  FRIENDLY
}

enum OUTREACH_GOAL {
  SALES
  NETWORKING
  PARTNERSHIPS
  BRAND_BUILDING
  BOOK_MEETING
}

model WorkflowRun {
  id           Int              @id @default(autoincrement())
  workflow     WORKFLOW_TYPE
  activity     WORKFLOW_ACTIVITY
  status       WORKFLOW_STATUS  @default(PENDING)
  workflow_id  String?          // Temporal workflow ID
  retry_count  Int              @default(0)
  error        String?          // last error message on failure
  sync_start   DateTime?
  sync_end     DateTime?

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([workflow])
}

enum WORKFLOW_TYPE {
  ONBOARD
}

enum WORKFLOW_ACTIVITY {
  PRODUCT_SCRAPE
  AGENT_GENERATE
}

enum WORKFLOW_STATUS {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
